# ── Resend (email) ──────────────────────────────────────────────────────────
# Get your key at https://resend.com → API Keys
# Emails go to console when this is missing (dev mode)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email addresses ──────────────────────────────────────────────────────────
# Must be a verified domain in your Resend account
RESEND_FROM=Maxxlab Forms <admin@maxxlab.tech>
ADMIN_EMAIL=admin@maxxlab.tech

# ── Base URL (used for submission viewer links in emails) ────────────────────
# Local dev:
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Production (Vercel):
# NEXT_PUBLIC_BASE_URL=https://forms.maxxlab.tech

# ── Neon PostgreSQL ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Migration secret (used for /api/migrate endpoint) ────────────────────────
MIGRATE_SECRET=your-secret-here

# ── Vercel Blob (file uploads) ────────────────────────────────────────────────
# Create a Blob store in your Vercel project → Storage tab, then copy its token.
# Without this set, the /api/upload endpoint returns 501 (uploads disabled).
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
